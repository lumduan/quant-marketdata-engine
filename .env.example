# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# `.env` and `.env.*` (except this example) are gitignored.

# ── Application ────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# Public/private mode. Public (default true) is read-only and refuses to fetch
# tvkit; set to false in owner/ingest mode so the engine may fetch & upsert.
MARKETDATA_ENGINE_PUBLIC_MODE=true

# Host port mapping (container always listens on :8000; host exposes :8300).
MARKETDATA_ENGINE_HOST_PORT=8300

# ── tvkit / TradingView credential (THIS SERVICE IS THE SOLE OWNER) ─────────
# TVKIT_AUTH_TOKEN holds a JSON *cookie string* (NOT a JWT). Required key:
# `sessionid`; optional: `sessionid_sign`, `device_t`, `tv_ecuid`.
#   {"device_t":"…","tv_ecuid":"…","sessionid":"…","sessionid_sign":"…"}
# Source it from a logged-in tradingview.com browser session.
# NEVER commit it. Keep it in this gitignored `.env` or a gitignored `.tmp/` file
# and inject with command substitution — see docs/plans/ROADMAP.md / the
# development-workflow playbook. Do NOT `set -a; . file` (JSON has spaces → it
# word-splits and silently falls back to the anonymous 5,000-bar cap).
TVKIT_AUTH_TOKEN=

# ── quant-infra-db (canonical TimescaleDB store) ───────────────────────────
# Inside quant-network use the service hostname `quant-postgres:5432`.
MARKETDATA_ENGINE_PG_DSN=postgresql://quant:quant@quant-postgres:5432/db_market_data

# ── Own Redis sidecar (hot-window cache + single-flight fetch lock) ─────────
# This is the engine's OWN Redis, distinct from the gateway's response cache.
# Inside quant-network use the sidecar service hostname `marketdata-redis`.
MARKETDATA_ENGINE_REDIS_URL=redis://marketdata-redis:6379/0

# ── Read-API auth (raw OHLCV is private-side only) ─────────────────────────
MARKETDATA_ENGINE_API_KEY=

# ── Optional tuning (sensible defaults in settings.py) ─────────────────────
# MARKETDATA_ENGINE_PG_POOL_MIN_SIZE=1
# MARKETDATA_ENGINE_PG_POOL_MAX_SIZE=10
# MARKETDATA_ENGINE_CACHE_TTL_SECONDS=300
# MARKETDATA_ENGINE_TVKIT_TIMEOUT_SECONDS=30
